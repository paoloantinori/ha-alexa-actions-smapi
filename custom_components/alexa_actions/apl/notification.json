{
  "type": "APL",
  "version": "2024.3",
  "import": [{"name": "alexa-layouts", "version": "2024.3"}],
  "mainTemplate": {
    "parameters": ["payload"],
    "items": [{
      "type": "Container",
      "height": "100vh",
      "width": "100vw",
      "paddingTop": "@spacing2XLarge",
      "paddingLeft": "@marginHorizontal",
      "paddingRight": "@marginHorizontal",
      "items": [
        {
          "type": "Text",
          "text": "${payload.notificationData.properties.title}",
          "fontSize": "@fontSizeDisplay3",
          "fontWeight": "bold",
          "maxLines": 2,
          "paddingBottom": "@spacingMedium"
        },
        {
          "type": "Text",
          "text": "${payload.notificationData.properties.body}",
          "fontSize": "@fontSizeMedium",
          "maxLines": 5,
          "paddingBottom": "@spacingLarge"
        },
        {
          "type": "Container",
          "when": "${payload.notificationData.properties.hasConfirmButton}",
          "direction": "row",
          "justifyContent": "center",
          "spacing": "@spacingMedium",
          "items": [
            {
              "type": "AlexaButton",
              "id": "confirmButton",
              "buttonText": "${payload.notificationData.properties.confirmLabel}",
              "primaryAction": [{
                "type": "SendEvent",
                "arguments": ["confirmAction"]
              }]
            },
            {
              "type": "AlexaButton",
              "id": "cancelButton",
              "buttonText": "${payload.notificationData.properties.cancelLabel}",
              "primaryAction": [{
                "type": "SendEvent",
                "arguments": ["cancelAction"]
              }]
            }
          ]
        }
      ]
    }]
  }
}
